{
  "expo": {
    "name": "Bookam",
    "slug": "bookam",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bookam",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#EEE9F5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bookam.app",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLName": "bookam",
            "CFBundleURLSchemes": [
              "bookam",
              "exp+bookam"
            ]
          }
        ],
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.bookam.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#6B2D82"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "bookam"
            },
            {
              "scheme": "exp+bookam"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      "expo-font",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3341966b-e4ac-4383-bf21-25921c8e6ce0"
      }
    },
    "notification": {
      "color": "#6B2D82"
    }
  }
}